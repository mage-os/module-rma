<?php

use MageOS\RMA\Block\Customer\Rma\View\Comments;

/**
 * @var Comments $block
 */

$comments = $block->getComments();
$rmaId = $block->getRmaId();

if (!$rmaId) {
    return;
}

$lastId = 0;
if (!empty($comments)) {
    $lastComment = end($comments);
    $lastId = $lastComment['entity_id'];
}

$downloadUrl = $block->getDownloadUrl();
?>
<div class="block block-rma-comments" id="rma-comments-section">
    <div class="block-title">
        <strong><?= $escaper->escapeHtml(__('Comments')) ?></strong>
    </div>
    <div class="block-content">
        <div id="rma-comments-timeline" class="rma-comments-timeline">
            <?php if (empty($comments)): ?>
                <p class="rma-no-comments"><?= $escaper->escapeHtml(__('No comments yet. Start the conversation!')) ?></p>
            <?php else: ?>
                <?php foreach ($comments as $comment): ?>
                    <div class="rma-comment <?= $escaper->escapeHtmlAttr($comment['author_type']) ?>"
                         data-comment-id="<?= (int)$comment['entity_id'] ?>">
                        <div class="rma-comment-meta">
                            <strong><?= $escaper->escapeHtml($comment['author_name']) ?></strong>
                            <?php if ($comment['author_type'] === 'admin'): ?>
                                <span class="rma-comment-badge"><?= $escaper->escapeHtml(__('Support')) ?></span>
                            <?php endif; ?>
                            <span class="rma-comment-date"><?= $escaper->escapeHtml($comment['created_at']) ?></span>
                        </div>
                        <div class="rma-comment-body"><?= $escaper->escapeHtml($comment['comment']) ?></div>
                        <?php if (!empty($comment['attachments'])): ?>
                            <div class="rma-comment-attachments">
                                <?php foreach ($comment['attachments'] as $att): ?>
                                    <div class="rma-comment-attachment-item">
                                        <a href="<?= $escaper->escapeUrl($downloadUrl . (str_contains($downloadUrl, '?') ? '&' : '?') . 'id=' . (int)$att['entity_id']) ?>"
                                           target="_blank" class="rma-attachment-link">
                                            &#128206; <?= $escaper->escapeHtml($att['file_name']) ?>
                                        </a>
                                    </div>
                                <?php endforeach; ?>
                            </div>
                        <?php endif; ?>
                    </div>
                <?php endforeach; ?>
            <?php endif; ?>
        </div>

        <div class="rma-comment-form">
            <div class="field">
                <textarea id="rma-comment-text" rows="3" class="input-text"
                          placeholder="<?= $escaper->escapeHtmlAttr(__('Type your message...')) ?>"></textarea>
            </div>
            <div class="rma-comment-upload-widget"
                 data-mage-init='{"MageOS_RMA/js/rma-file-upload": {
                     "uploadUrl": "<?= $escaper->escapeUrl($block->getUploadUrl()) ?>",
                     "allowedExtensions": "<?= $escaper->escapeHtmlAttr($block->getAllowedExtensions()) ?>",
                     "maxFileSize": <?= (int)$block->getMaxFileSize() ?>,
                     "maxFiles": <?= (int)$block->getMaxFiles() ?>,
                     "formKey": "<?= $escaper->escapeJs($block->getFormKey()) ?>"
                 }}'>
                <div class="rma-upload-dropzone">
                    <p class="rma-upload-dropzone-text"><?= $escaper->escapeHtml(__('Drag & drop files here or click to browse')) ?></p>
                    <p class="rma-upload-dropzone-hint">
                        <?= $escaper->escapeHtml(__('Allowed: %1 | Max size: %2 MB | Max files: %3', $block->getAllowedExtensions(), $block->getMaxFileSize(), $block->getMaxFiles())) ?>
                    </p>
                </div>
                <input type="file" class="rma-upload-input" multiple/>
                <div class="rma-upload-list"></div>
                <input type="hidden" class="rma-upload-data" value="[]"/>
            </div>
            <div class="actions-toolbar">
                <div class="primary">
                    <button type="button" id="rma-comment-submit" class="action submit primary">
                        <span><?= $escaper->escapeHtml(__('Send')) ?></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/x-magento-init">
{
    "#rma-comments-section": {
        "MageOS_RMA/js/rma-comments": {
            "rmaId": <?= (int)$rmaId ?>,
            "saveUrl": "<?= $escaper->escapeJs($block->getSaveUrl()) ?>",
            "loadListUrl": "<?= $escaper->escapeJs($block->getLoadListUrl()) ?>",
            "lastCommentId": <?= (int)$lastId ?>,
            "isAdmin": false,
            "downloadUrl": "<?= $escaper->escapeJs($block->getDownloadUrl()) ?>"
        }
    }
}
</script>
