<?php

use MageOS\RMA\Block\Customer\Rma\View;

/**
 * @var View $block
 */

$rma = $block->getRma();
if (!$rma) {
    return;
}
$items = $block->getRmaItems();
$attachments = $block->getAttachments();
?>
<div class="block block-rma-view">
    <div class="block-title">
        <a href="<?= $escaper->escapeUrl($block->getBackUrl()) ?>" class="action back">
            <span><?= $escaper->escapeHtml(__('Back to My Returns')) ?></span>
        </a>
    </div>

    <div class="block-content">
        <div class="box box-rma-info">
            <strong class="box-title">
                <span><?= $escaper->escapeHtml(__('Return Information')) ?></span>
            </strong>
            <div class="box-content">
                <table class="data table table-rma-info">
                    <tbody>
                        <tr>
                            <th scope="row"><?= $escaper->escapeHtml(__('RMA #')) ?></th>
                            <td><?= $escaper->escapeHtml($rma->getIncrementId()) ?></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $escaper->escapeHtml(__('Order #')) ?></th>
                            <td>#<?= $escaper->escapeHtml($block->getOrderIncrementId()) ?></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $escaper->escapeHtml(__('Status')) ?></th>
                            <td><strong><?= $escaper->escapeHtml($block->getStatusLabel()) ?></strong></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $escaper->escapeHtml(__('Reason')) ?></th>
                            <td><?= $escaper->escapeHtml($block->getReasonLabel()) ?></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $escaper->escapeHtml(__('Preferred Resolution')) ?></th>
                            <td><?= $escaper->escapeHtml($block->getResolutionTypeLabel()) ?></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $escaper->escapeHtml(__('Created At')) ?></th>
                            <td><?= $escaper->escapeHtml($block->formatDate($rma->getCreatedAt(), \IntlDateFormatter::MEDIUM, true)) ?></td>
                        </tr>
                        <tr>
                            <th scope="row"><?= $escaper->escapeHtml(__('Updated At')) ?></th>
                            <td><?= $escaper->escapeHtml($block->formatDate($rma->getUpdatedAt(), \IntlDateFormatter::MEDIUM, true)) ?></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <?php if (!empty($items)): ?>
            <div class="box box-rma-items">
                <strong class="box-title">
                    <span><?= $escaper->escapeHtml(__('Items to Return')) ?></span>
                </strong>
                <div class="box-content">
                    <div class="table-wrapper">
                        <table class="data table table-rma-items">
                            <thead>
                                <tr>
                                    <th scope="col"><?= $escaper->escapeHtml(__('Product')) ?></th>
                                    <th scope="col"><?= $escaper->escapeHtml(__('SKU')) ?></th>
                                    <th scope="col"><?= $escaper->escapeHtml(__('Quantity')) ?></th>
                                    <th scope="col"><?= $escaper->escapeHtml(__('Condition')) ?></th>
                                </tr>
                            </thead>
                            <tbody>
                                <?php foreach ($items as $item): ?>
                                    <tr>
                                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Product')) ?>">
                                            <?= $escaper->escapeHtml($item['name']) ?>
                                        </td>
                                        <td data-th="<?= $escaper->escapeHtmlAttr(__('SKU')) ?>">
                                            <?= $escaper->escapeHtml($item['sku']) ?>
                                        </td>
                                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Quantity')) ?>">
                                            <?= (int)$item['qty_requested'] ?>
                                        </td>
                                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Condition')) ?>">
                                            <?= $escaper->escapeHtml($item['condition_label']) ?>
                                        </td>
                                    </tr>
                                <?php endforeach; ?>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        <?php endif; ?>

        <div class="box box-rma-attachments">
            <strong class="box-title">
                <span><?= $escaper->escapeHtml(__('Attachments')) ?></span>
            </strong>
            <div class="box-content">
                <ul id="rma-all-attachments" class="rma-attachment-list">
                    <?php if (empty($attachments)): ?>
                        <li class="rma-no-attachments">
                            <?= $escaper->escapeHtml(__('No attachments yet.')) ?>
                        </li>
                    <?php else: ?>
                        <?php foreach ($attachments as $att): ?>
                            <li class="rma-attachment-item" data-attachment-id="<?= (int)$att['entity_id'] ?>">
                                <a href="<?= $escaper->escapeUrl($block->getDownloadUrl((int)$att['entity_id'])) ?>"
                                   class="rma-attachment-link">
                                    &#128206; <?= $escaper->escapeHtml($att['file_name']) ?>
                                </a>
                                <span class="rma-attachment-size">
                                    (<?= $escaper->escapeHtml($att['file_size_label']) ?>)
                                </span>
                            </li>
                        <?php endforeach; ?>
                    <?php endif; ?>
                </ul>
            </div>
        </div>
    </div>
</div>
